{
  "projectType": "saas",
  "projectName": "Backus Simulador de Camiones",
  "projectDescription": "A real-time yard management web application for Backus that tracks truck queues, bay assignments, incidents, and shift-based logistics metrics through an interactive drag-and-drop interface backed by Supabase.",
  "theme": "linden",
  "primaryColor": "#7c3aed",
  "lightColor": "#a78bfa",
  "darkColor": "#4c1d95",

  "keyFeatures": [
    "Interactive drag-and-drop yard map with configurable bay assignments",
    "Real-time queue management with traffic-light wait-time alerts (green/yellow/red)",
    "Dual mode: simulation mode for training and real mode synced with Supabase",
    "Role-based access: admin can configure thresholds, client has read-only monitoring",
    "Incident tracking per truck (up to 3 per vehicle) with net time deduction from averages",
    "Live dashboard panels: priority unit, average yard time, and per-shift truck counts",
    "Mobile-responsive layout with tap-to-assign for touch devices",
    "Session and daily reports with shift breakdowns (T1/T2/T3)"
  ],
  "publicApiSurface": [
    "fetchCamionesCola(): Promise<Camion[]>",
    "fetchUnidadPrioridad(): Promise<VwUnidadPrioridad | null>",
    "fetchDashboardTurnos(): Promise<VwDashboardTurnos | null>",
    "fetchPromedioPatioNeto(): Promise<VwPromedioPatioNeto | null>",
    "abrirIncidencia(id_camion: number): Promise<AbrirIncidenciaResult>",
    "cerrarIncidencia(id_camion: number): Promise<IncidenciaRow | null>",
    "contarIncidencias(id_camion: number): Promise<number>",
    "actualizarBahiaDirecto(id_viaje, bahia_actual, estado): Promise<boolean>",
    "marcarSalidaDirecto(id_viaje: string): Promise<boolean>",
    "loginUsuario(email, password): Promise<UsuarioLogin | null>",
    "intervalAMinutos(interval: string): number",
    "intervalATexto(interval: string): string"
  ]
}
